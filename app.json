{
  "expo": {
    "name": "우리집 설명서",
    "slug": "woorijip",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "woorijip",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "com.woorijip.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-video",
      [
        "expo-media-library",
        {
          "savePhotosPermission": "만든 QR 이미지를 사진첩에 저장합니다.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "갤러리에서 설명 영상을 가져오기 위해 사진 접근을 사용합니다."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "부모님께 보여줄 설명 영상을 촬영하기 위해 카메라를 사용합니다.",
          "microphonePermission": "설명 영상의 소리를 녹음하기 위해 마이크를 사용합니다.",
          "recordAudioAndroid": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
